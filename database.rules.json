{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "roleBindings": {
      "$uid": {
        ".read": "$uid === auth.uid || root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'",
        ".write": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'",
        ".validate": "newData.hasChildren(['role','name']) && (newData.child('role').val() === 'admin' || newData.child('role').val() === 'staff')"
      }
    },
    "employees": {
      ".read": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'"
    },
    "systemSettings": {
      ".write": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'"
    },
    "backups": {
      ".read": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'",
      ".write": "root.child('roleBindings').child(auth.uid).child('role').val() === 'admin'"
    }
  }
}
