<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:padding="10dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Monster Hardware Explorer v1.0 · Sprint 6 PWA Cash" android:textSize="21sp" android:textStyle="bold" />
    <TextView android:id="@+id/statusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="5dp" android:textSize="13sp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Spinner android:id="@+id/portSpinner" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" />
        <Spinner android:id="@+id/baudSpinner" android:layout_width="120dp" android:layout_height="48dp" />
        <Button android:id="@+id/connectButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="連線" />
        <Button android:id="@+id/disconnectButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="中斷" />
    </LinearLayout>
    <TextView android:id="@+id/statsText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#EEEEEE" android:fontFamily="monospace" android:padding="6dp" android:textSize="12sp" />
    <TextView android:id="@+id/bridgeStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E8F5E9" android:fontFamily="monospace" android:padding="6dp" android:text="本機售票橋接啟動中" android:textIsSelectable="true" android:textSize="12sp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingTop="4dp" android:text="售票訂單＋現金付款（ttyS1 · 不找零）" android:textStyle="bold" />
    <TextView android:id="@+id/orderStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E8EAF6" android:fontFamily="monospace" android:padding="6dp" android:text="尚無售票訂單" android:textSize="12sp" />
    <TextView android:id="@+id/paymentStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E3F2FD" android:fontFamily="monospace" android:padding="6dp" android:text="待機｜輸入應付金額後開始" android:textSize="12sp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/orderIdInput" android:layout_width="150dp" android:layout_height="wrap_content" android:hint="訂單編號" android:inputType="textNoSuggestions" android:maxLength="80" android:selectAllOnFocus="true" />
        <EditText android:id="@+id/paymentAmountInput" android:layout_width="100dp" android:layout_height="wrap_content" android:hint="應付金額" android:inputType="number" android:maxLength="4" android:selectAllOnFocus="true" android:text="110" />
        <Button android:id="@+id/startPaymentButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="建立訂單並收款" />
        <Button android:id="@+id/cancelPaymentButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="取消並停止收款" />
        <Button android:id="@+id/reconcilePaymentButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="確認已人工處理" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/retryPrintButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="重送同一出票授權" />
        <Button android:id="@+id/simulateTicketIssuedButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="測試：售票機確認已出票" />
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingTop="4dp" android:text="MDB 安全補幣（ttyS1 · 9600）" android:textStyle="bold" />
    <TextView android:id="@+id/mdbSafetyStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E8F5E9" android:fontFamily="monospace" android:padding="6dp" android:text="補幣已停用｜等待 ttyS1 連線" android:textSize="12sp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/startCoinFillButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="開始補幣（60秒）" />
        <Button android:id="@+id/stopCoinFillButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="停止補幣" />
        <Button android:id="@+id/tubeInfoButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="查詢硬幣機 Tube" />
    </LinearLayout>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:paddingTop="4dp" android:text="紙鈔安全測試（收鈔器在 ttyS1 · 9600）" android:textStyle="bold" />
    <TextView android:id="@+id/billSafetyStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFF3E0" android:fontFamily="monospace" android:padding="6dp" android:text="收鈔已停用｜等待 ttyS1 連線" android:textSize="12sp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/startBillTestButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="單張100元測試（60秒）" />
        <Button android:id="@+id/stopBillTestButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="立即停止收鈔" />
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/pauseButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="暫停顯示" />
        <Button android:id="@+id/clearButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="清除畫面" />
        <Button android:id="@+id/exportButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="匯出 ZIP" />
    </LinearLayout>
    <TextView android:id="@+id/exportStatusText" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="4dp" android:text="匯出狀態：尚未建立 ZIP" android:textSize="12sp" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/shareLastButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="分享上次 ZIP" />
        <Button android:id="@+id/saveLastButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:enabled="false" android:text="儲存 ZIP 副本" />
    </LinearLayout>
    <ScrollView android:id="@+id/logScroll" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <TextView android:id="@+id/logText" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="monospace" android:textIsSelectable="true" android:textSize="12sp" />
    </ScrollView>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Command Library" android:textStyle="bold" />
    <Spinner android:id="@+id/commandSpinner" android:layout_width="match_parent" android:layout_height="44dp" />
    <EditText android:id="@+id/txInput" android:layout_width="match_parent" android:layout_height="wrap_content" android:fontFamily="monospace" android:hint="HEX" android:inputType="textNoSuggestions" />
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <Button android:id="@+id/addQueueButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="加入目前 Port Queue" />
        <Button android:id="@+id/sendButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="傳送下一筆" />
        <Button android:id="@+id/sendAllButton" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="傳送全部" />
    </LinearLayout>
    <TextView android:id="@+id/queueText" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#F5F5F5" android:fontFamily="monospace" android:maxLines="3" android:padding="5dp" android:textSize="12sp" />
    <CheckBox android:id="@+id/txUnlockCheck" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="解除 TX 鎖定 60 秒（MDB Reset、出幣、支付與未知指令仍會封鎖）" />
</LinearLayout>
