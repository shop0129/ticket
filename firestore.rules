rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isManager() {
      return signedIn() && request.auth.token.staff == true && request.auth.token.role == 'admin';
    }

    function isStaff() {
      return signedIn() && request.auth.token.staff == true &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'staff');
    }

    function isKiosk() {
      return signedIn() && request.auth.token.device == true;
    }

    match /ticketTypes/{ticketId} {
      allow read: if isStaff() || isKiosk();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isStaff() || isKiosk();
      allow create: if isStaff() || isKiosk();
      allow update: if isManager() ||
        (isStaff() && !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'cancelledAt', 'cancelledBy', 'cancelledById', 'deleted']));
      allow delete: if false;
    }

    match /members/{memberId} {
      allow read, create: if isStaff();
      allow update: if isManager() ||
        (isStaff() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['deleted']));
      allow delete: if isManager();
    }

    match /staffUsers/{staffId} {
      allow read: if isManager() || (isStaff() && request.auth.uid == staffId);
      allow write: if false;
    }

    match /systemSettings/{settingId} {
      allow read: if isStaff() || isKiosk();
      allow write: if isManager();
    }

    match /dailyStats/{statId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /auditLogs/{logId} {
      allow read: if isManager();
      allow create: if isStaff() || isKiosk();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
