rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isManager() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function isStaff() {
      return signedIn() &&
        (request.auth.token.role == 'admin' || request.auth.token.role == 'staff');
    }

    function isKiosk() {
      return signedIn() && request.auth.token.device == true;
    }

    match /ticketTypes/{ticketId} {
      allow read: if isStaff() || isKiosk();
      allow write: if isManager();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create: if isStaff() || isKiosk();
      allow update: if isStaff() &&
        (!request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(['status', 'cancelledAt', 'cancelledBy', 'cancelledById']))
        || isManager();
      allow delete: if false;
    }

    match /members/{memberId} {
      allow read, create, update: if isStaff();
      allow delete: if isManager();
    }

    match /staffUsers/{staffId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /systemSettings/{settingId} {
      allow read: if isStaff() || isKiosk();
      allow write: if isManager();
    }

    match /dailyStats/{statId} {
      allow read: if isStaff();
      allow write: if isManager();
    }

    match /cashReconciliations/{recordId} {
      allow read: if isStaff();
      allow create: if isKiosk() || isManager();
      allow update: if isManager();
      allow delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isManager();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
