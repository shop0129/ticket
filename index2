<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>親子樂園售票機</title>

<style>

body{
    margin:0;
    padding:0;
    font-family:sans-serif;
    background:#f5f5f5;
    overflow:hidden;
}

/* 共用頁面 */

.page{
    width:100vw;
    height:100vh;

    display:none;

    flex-direction:column;

    align-items:center;

    overflow-y:auto;

    padding:30px 0 50px;
}

.active{
    display:flex;
}

/* 標題 */

.title{
    font-size:56px;
    font-weight:bold;
    color:#444;
    margin-top:30px;
    margin-bottom:25px;
}

/* 大按鈕 */

.big-btn{

    width:80%;

    max-width:600px;

    height:90px;

    font-size:34px;

    font-weight:bold;

    border:none;

    border-radius:25px;

    margin:12px;

    background:white;

    color:#333;

    box-shadow:0 8px 20px rgba(0,0,0,0.12);
}
/* 票券卡片 */

.ticket-card{
    background:white;
    width:85%;
    max-width:750px;
    border-radius:25px;
    padding:30px;
    margin-bottom:30px;
    box-shadow:0 5px 20px rgba(0,0,0,0.2);
    text-align:center;
}

.ticket-title{
    font-size:56px;
    font-weight:bold;
}

.ticket-content{
    font-size:40px;
    margin-top:15px;
    line-height:1.8;
}

.ticket-price{
    font-size:90px;
    color:red;
    margin-top:20px;
    font-weight:bold;
}

/* 返回按鈕 */

.back-btn{
    position:absolute;

    top:20px;
    left:20px;

    width:90px;
    height:45px;

    font-size:24px;

    border:none;
    border-radius:15px;

    background:#ff9800;
    color:white;

    z-index:999;
}
.home-page{

    background-image:url('images/home-bg.png');

    background-size:cover;
    background-position:center;
    background-repeat:no-repeat;

    position:relative;
}
#ticketPage{
    position:relative;

    background-image:url('images/ticket-bg.png');
    background-size:cover;
    background-position:center;
}

#ticketPage::before{
    content:'';

    position:absolute;

    top:0;
    left:0;

    width:100%;
    height:100%;

    background:rgba(255,255,255,0.55);

    z-index:0;
}

#ticketPage .category-title,
#ticketPage .ticket-btn,
#ticketPage .back-btn{
    position:relative;
    z-index:1;
}
    .start-btn:active{
    transform:translateX(-50%) scale(0.95);
}

    .start-btn{

    position:absolute;

    bottom:120px;

    left:50%;

    transform:translateX(-50%);

    width:65%;

    max-width:500px;

    height:auto;

    cursor:pointer;

    z-index:10;
}

.start-btn:hover{
    transform:translateX(-50%) scale(1.03);
}
    /* 分類標題 */

.category-title{

    width:320px;

    margin:35px 0 15px;

}

/* 票券圖片 */

.ticket-btn{

    width:340px;

    height:auto;

    cursor:pointer;

    transition:.2s;

}

.ticket-btn:hover{

    transform:scale(1.02);

}

.ticket-btn:active{

    transform:scale(.98);

}
    .ticket-row{
    display:flex;
    justify-content:center;
    gap:20px;

    width:100%;

    margin-bottom:15px;

    position:relative;
    z-index:1;
}
</style>
</head>

<body>

